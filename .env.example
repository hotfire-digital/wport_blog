# Static blog build does not require any env vars to succeed.
# Analytics / Search Console (optional, available at build time via PUBLIC_*):

# Google Tag Manager container ID (defaults to wport.me root container GTM-MGLNLCG5)
PUBLIC_GTM_ID=GTM-MGLNLCG5

# Google Search Console HTML meta verification token (only needed for meta-tag method)
PUBLIC_GSC_VERIFICATION=

# The variables below are only for scripts/upload_to_cloudinary.py (optional).

CLOUDINARY_CLOUD_NAME=dyebbsckc
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
