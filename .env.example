# Static blog build does not require any env vars to succeed.
# Analytics / Search Console (optional, available at build time via PUBLIC_*):

# Google Tag Manager container ID (defaults to wport.me root container GTM-MGLNLCG5)
PUBLIC_GTM_ID=GTM-MGLNLCG5

# Google Search Console HTML meta verification token (only needed for meta-tag method)
PUBLIC_GSC_VERIFICATION=

# In-article job recommendations (same origin as the blog in production, so no
# CORS handling is needed). Posts with `jobKeywords` search general jobs by topic
# (SEARCH_URL is the "看更多" link, {kw} substituted); posts tagged 僑外生 fall
# back to the foreign-student zone (ZONE_URL). {enc_id} substituted at runtime.
PUBLIC_JOBS_API_BASE=https://wport.me/v2/api
PUBLIC_JOB_DETAIL_URL=https://wport.me/job/{enc_id}
PUBLIC_JOB_SEARCH_URL=https://wport.me/jobs?keyword={kw}
PUBLIC_JOB_ZONE_URL=https://wport.me/foreign-student-zone

# The variables below are only for scripts/upload_to_cloudinary.py (optional).

CLOUDINARY_CLOUD_NAME=dyebbsckc
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
