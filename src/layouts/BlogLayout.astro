---
import "../styles/global.css";
import BlogFooter from "@/components/BlogFooter.astro";
import { getGtmId } from "@/lib/analytics";
import {
  defaultLocale,
  localeHtmlLang,
  localeOg,
  locales,
  type Locale,
} from "@/i18n/locales";
import { localizedCanonicalUrl, t } from "@/i18n/utils";

interface Props {
  title?: string;
  description?: string;
  cover?: string;
  publishDate?: Date;
  tags?: string[];
  canonicalUrl?: string;
  locale?: Locale;
  /** Logical path without locale prefix, e.g. `/`, `/archive`, `/posts/foo/` */
  alternatePath?: string;
  alternateUrls?: Partial<Record<Locale, string>>;
}

const {
  title = "Wport Blog",
  description,
  cover,
  publishDate,
  tags = [],
  canonicalUrl,
  locale = defaultLocale,
  alternatePath = "/",
  alternateUrls,
} = Astro.props;

const resolvedDescription = description ?? t(locale, "layout.defaultDescription");

const baseUrl = import.meta.env.BASE_URL;
const normalizedBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const siteUrl = "https://wport.me";
const blogBasePath = import.meta.env.BASE_URL.replace(/\/$/, "") || "/blog";
const rssFeedUrl = `${siteUrl}${blogBasePath}/feed.xml`;
const siteName = t(locale, "layout.siteName");
const fullTitle = title === "Wport Blog" ? title : `${title} | ${siteName}`;
const ogImage = cover || `${siteUrl}/template.png`;
const canonical = canonicalUrl || Astro.url.href;
const publishedTime = publishDate?.toISOString();
const gtmId = getGtmId();
const gscVerification = (import.meta.env.PUBLIC_GSC_VERIFICATION as string | undefined)?.trim();

const hreflangLinks = locales.map((loc) => ({
  hreflang: localeHtmlLang[loc],
  href: alternateUrls?.[loc] ?? localizedCanonicalUrl(loc, alternatePath),
}));
---

<!doctype html>
<html lang={localeHtmlLang[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href={withBase("/favicon.ico")} />
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
    <link rel="preconnect" href="https://images.pexels.com" crossorigin />
    {
      gtmId && (
        <script is:inline define:vars={{ gtmId }}>
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
            var f = d.getElementsByTagName(s)[0],
              j = d.createElement(s),
              dl = l != "dataLayer" ? "&l=" + l : "";
            j.async = true;
            j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, "script", "dataLayer", gtmId);
        </script>
      )
    }
    <slot name="head" />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${siteName} Blog RSS`} href={rssFeedUrl} />
    {
      hreflangLinks.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={localizedCanonicalUrl(defaultLocale, alternatePath)} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}
    <meta name="author" content={siteName} />
    <meta name="robots" content="index, follow" />
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}

    <!-- Open Graph -->
    <meta property="og:type" content={publishDate ? "article" : "website"} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={localeOg[locale]} />
    {
      locales
        .filter((loc) => loc !== locale)
        .map((loc) => <meta property="og:locale:alternate" content={localeOg[loc]} />)
    }
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@wport_me" />

    <!-- JSON-LD Structured Data -->
    {publishDate && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": title,
        "description": resolvedDescription,
        "image": ogImage,
        "datePublished": publishedTime,
        "inLanguage": localeHtmlLang[locale],
        "author": {
          "@type": "Organization",
          "name": siteName,
          "url": siteUrl,
        },
        "publisher": {
          "@type": "Organization",
          "name": siteName,
          "url": siteUrl,
          "logo": {
            "@type": "ImageObject",
            "url": `${siteUrl}/wport.svg`,
          },
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonical,
        },
      })} />
    )}
  </head>
  <body class="page-shell">
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          ></iframe>
        </noscript>
      )
    }
    <slot />
    <BlogFooter locale={locale} />
  </body>
</html>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    width: 100%;
    min-height: 100%;
  }

  .page-shell {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  body {
    font-family: "PingFang TC", "Microsoft JhengHei", "Helvetica Neue", Arial, sans-serif;
    font-size: 16px;
    line-height: 1.85;
    color: #5D5D5D;
    background: #FFFFFF;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #D7D7D7; border-radius: 3px; }

  @media (prefers-reduced-motion: no-preference) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 220ms;
      animation-timing-function: ease;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none;
    }
  }
</style>
