---
interface Props {
  currentPage?: "home" | "archive";
}
const { currentPage } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const normalizedBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<nav class="topbar">
  <div class="topbar-inner">
    <!-- Logo -->
    <a href={withBase("/")} title="Wport Blog" class="topbar-logo">
      <img src={withBase("/wport.svg")} alt="WPORT" width="77" height="37" class="topbar-logo-image" />
    </a>

    <!-- Right nav -->
    <nav class="topbar-nav">
      <a href={withBase("/")} class:list={["topbar-link", { "topbar-link--active": currentPage === "home" }]}>首頁</a>
      <a href={withBase("/archive")} class:list={["topbar-link", { "topbar-link--active": currentPage === "archive" }]}>所有文章</a>
    </nav>
  </div>
</nav>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg-page);
    border-bottom: 1px solid var(--border-default);
    font-family: var(--font-sans);
  }

  .topbar-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .topbar-logo {
    padding: 0 24px;
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .topbar-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    padding-right: 16px;
  }

  .topbar-link {
    font-size: 14px;
    color: var(--fg-primary);
    text-decoration: none;
    padding: 6px 14px;
    border-radius: 6px;
    transition:
      background 150ms ease,
      color 150ms ease;
    border-bottom: 2px solid transparent;
  }

  .topbar-link:hover {
    background: var(--bg-hover);
    color: var(--fg-heading);
  }

  .topbar-link--active {
    color: var(--color-primary);
    font-weight: 600;
    border-bottom-color: var(--color-primary);
    border-radius: 0;
    background: transparent;
  }

  .topbar-link--active:hover {
    background: transparent;
    color: var(--color-primary-hover);
  }

  .topbar-logo-image {
    object-fit: contain;
    display: block;
  }
</style>
