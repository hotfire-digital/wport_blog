---
import {
  defaultLocale,
  localeLabels,
  locales,
  type Locale,
} from "@/i18n/locales";
import { jobsUrlForLocale, localizedPath, t } from "@/i18n/utils";

interface Props {
  currentPage?: "home" | "archive";
  locale?: Locale;
  languageHrefs?: Partial<Record<Locale, string>>;
}

const {
  currentPage,
  locale = defaultLocale,
  languageHrefs = {},
} = Astro.props;

const homeHref = localizedPath(locale, "/");
const archiveHref = localizedPath(locale, "/archive");
const jobsHref = jobsUrlForLocale(locale);
const assetBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const langOptions = locales.map((loc) => ({
  loc,
  label: localeLabels[loc],
  href: languageHrefs[loc] ?? localizedPath(loc, "/"),
  current: loc === locale,
}));
---

<nav class="topbar">
  <div class="topbar-inner">
    <a href={homeHref} title="Wport Blog" class="topbar-logo">
      <img src={`${assetBase}wport.svg`} alt="WPORT" width="77" height="37" class="topbar-logo-image" />
    </a>

    <nav class="topbar-nav">
      <a href={homeHref} class:list={["topbar-link", { "topbar-link--active": currentPage === "home" }]}
        >{t(locale, "nav.home")}</a
      >
      <a
        href={archiveHref}
        class:list={["topbar-link", { "topbar-link--active": currentPage === "archive" }]}
        >{t(locale, "nav.archive")}</a
      >
      <a href={jobsHref} class="topbar-link topbar-link--cta" target="_blank" rel="noopener noreferrer"
        >{t(locale, "nav.jobs")}</a
      >

      <div class="topbar-lang" data-lang-menu>
        <button
          type="button"
          class="topbar-lang-trigger"
          aria-label={t(locale, "nav.language")}
          aria-haspopup="listbox"
          aria-expanded="false"
          data-lang-trigger
        >
          <span data-lang-label>{localeLabels[locale]}</span>
          <svg class="topbar-lang-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <polyline
              points="6 9 12 15 18 9"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></polyline>
          </svg>
        </button>
        <ul class="topbar-lang-menu" role="listbox" hidden data-lang-panel>
          {
            langOptions.map((opt) => (
              <li role="option" aria-selected={opt.current}>
                <a
                  href={opt.href}
                  class:list={["topbar-lang-option", { "topbar-lang-option--active": opt.current }]}
                  hreflang={opt.loc}
                  data-lang-option
                >
                  {opt.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>
  </div>
</nav>

<script>
  function initLangMenus() {
    document.querySelectorAll("[data-lang-menu]").forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.bound === "1") return;
      root.dataset.bound = "1";

      const trigger = root.querySelector("[data-lang-trigger]");
      const panel = root.querySelector("[data-lang-panel]");
      if (!(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

      const setOpen = (open) => {
        panel.hidden = !open;
        trigger.setAttribute("aria-expanded", open ? "true" : "false");
        root.classList.toggle("is-open", open);
      };

      trigger.addEventListener("click", (event) => {
        event.stopPropagation();
        setOpen(panel.hidden);
      });

      panel.addEventListener("click", (event) => event.stopPropagation());

      document.addEventListener("click", () => setOpen(false));
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setOpen(false);
      });
    });
  }

  initLangMenus();
  document.addEventListener("astro:page-load", initLangMenus);
</script>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg-page);
    border-bottom: 1px solid var(--border-default);
    font-family: var(--font-sans);
  }

  .topbar-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .topbar-logo {
    padding: 0 24px;
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .topbar-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    padding-right: 16px;
  }

  .topbar-link {
    font-size: 14px;
    color: var(--fg-primary);
    text-decoration: none;
    padding: 6px 14px;
    border-radius: 6px;
    transition:
      background 150ms ease,
      color 150ms ease;
    border-bottom: 2px solid transparent;
    line-height: 1.2;
    box-sizing: border-box;
  }

  .topbar-link:hover {
    background: var(--bg-hover);
    color: var(--fg-heading);
  }

  .topbar-link--active {
    color: var(--color-primary);
    font-weight: 600;
    border-bottom-color: var(--color-primary);
    border-radius: 0;
    background: transparent;
  }

  .topbar-link--active:hover {
    background: transparent;
    color: var(--color-primary-hover);
  }

  .topbar-link--cta {
    background: var(--color-primary);
    color: #fff;
    border-bottom: none;
    font-weight: 600;
    min-height: 32px;
    display: inline-flex;
    align-items: center;
  }

  .topbar-link--cta:hover {
    background: var(--color-primary-hover);
    color: #fff;
  }

  .topbar-logo-image {
    object-fit: contain;
    display: block;
  }

  .topbar-lang {
    position: relative;
    margin-left: 4px;
  }

  .topbar-lang-trigger {
    appearance: none;
    font: inherit;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-primary);
    background: var(--color-primary-light);
    border: 1px solid var(--color-primary);
    border-radius: 6px;
    padding: 6px 12px;
    min-height: 32px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition:
      background-color 150ms ease,
      border-color 150ms ease,
      color 150ms ease;
  }

  .topbar-lang-trigger:hover,
  .topbar-lang.is-open .topbar-lang-trigger {
    background: #d8f1ee;
    border-color: var(--color-primary-hover);
    color: var(--color-primary-hover);
  }

  .topbar-lang-trigger:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-primary) 35%, transparent);
    outline-offset: 2px;
  }

  .topbar-lang-chevron {
    flex-shrink: 0;
    transition: transform 150ms ease;
  }

  .topbar-lang.is-open .topbar-lang-chevron {
    transform: rotate(180deg);
  }

  .topbar-lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    z-index: 60;
    min-width: 100%;
    width: max-content;
    margin: 0;
    padding: 6px;
    list-style: none;
    background: #fff;
    border: 1px solid var(--color-primary);
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(13, 124, 112, 0.12);
  }

  .topbar-lang-option {
    display: block;
    padding: 8px 12px;
    border-radius: 6px;
    color: var(--color-primary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    transition:
      background-color 150ms ease,
      color 150ms ease;
  }

  .topbar-lang-option:hover {
    background: var(--color-primary-light);
    color: var(--color-primary-hover);
  }

  .topbar-lang-option--active {
    background: var(--color-primary);
    color: #fff;
  }

  .topbar-lang-option--active:hover {
    background: var(--color-primary-hover);
    color: #fff;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .topbar-nav {
      gap: 2px;
      padding-right: 8px;
    }

    .topbar-link {
      font-size: 13px;
      padding: 6px 10px;
    }

    .topbar-lang-trigger {
      font-size: 12px;
      padding: 6px 10px;
      gap: 6px;
    }

    .topbar-lang-option {
      font-size: 13px;
    }
  }
</style>
