---
import SiteImage from "@/components/SiteImage.astro";
import { defaultLocale, type Locale } from "@/i18n/locales";
import { mainSitePath, t } from "@/i18n/utils";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const year = new Date().getFullYear();

const links = [
  { label: t(locale, "footer.about"), href: mainSitePath(locale, "/about-us") },
  { label: t(locale, "footer.contact"), href: mainSitePath(locale, "/contact-us") },
];

const socials = [
  {
    href: "https://www.facebook.com/wportjobstation/",
    src: "/icons/footer/footer_facebook.png",
    alt: t(locale, "footer.facebook.alt"),
    ariaLabel: t(locale, "footer.facebook.aria"),
    title: "wport Facebook",
  },
  {
    href: "https://www.instagram.com/wport.me/",
    src: "/icons/footer/footer_instagram.png",
    alt: t(locale, "footer.instagram.alt"),
    ariaLabel: t(locale, "footer.instagram.aria"),
    title: "wport Instagram",
  },
  {
    href: "https://www.tiktok.com/@wport.me",
    src: "/icons/footer/footer_tiktok.png",
    alt: t(locale, "footer.tiktok.alt"),
    ariaLabel: t(locale, "footer.tiktok.aria"),
    title: "wport TikTok",
  },
  {
    href: "https://www.youtube.com/@wport-me",
    src: "/icons/footer/footer_youtube.png",
    alt: t(locale, "footer.youtube.alt"),
    ariaLabel: t(locale, "footer.youtube.aria"),
    title: "wport YouTube",
  },
  {
    href: "https://www.linkedin.com/company/w101人力銀行",
    src: "/icons/footer/footer_linkedin.png",
    alt: t(locale, "footer.linkedin.alt"),
    ariaLabel: t(locale, "footer.linkedin.aria"),
    title: "wport LinkedIn",
  },
];

const copyright = t(locale, "footer.copyright", { year });
---

<footer class="blog-footer">
  <section class="blog-footer__top">
    <nav class="blog-footer__links" aria-label={t(locale, "footer.siteLinks")}>
      {
        links.map((item) => (
          <p>
            <a href={item.href} target="_blank" rel="noopener noreferrer">
              {item.label}
            </a>
          </p>
        ))
      }
    </nav>

    <section class="blog-footer__socials" aria-label={t(locale, "footer.socials")}>
      {
        socials.map((social) => (
          <a
            href={social.href}
            aria-label={social.ariaLabel}
            title={social.title}
            target="_blank"
            rel="noopener noreferrer"
          >
            <SiteImage
              src={social.src}
              alt={social.alt}
              context="icon"
              class="blog-footer__social-icon"
              width={24}
              height={24}
              loading="lazy"
            />
          </a>
        ))
      }
    </section>
  </section>

  <section class="blog-footer__copyright-wrap">
    <p class="blog-footer__copyright">{copyright}</p>
  </section>
</footer>

<style>
  .blog-footer {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: auto;
    border-top: 1px solid var(--border-default);
    background: var(--bg-page);
  }

  .blog-footer__top {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 72rem;
    margin: 0 auto;
    width: 100%;
    align-items: center;
    justify-content: center;
  }

  .blog-footer__links {
    display: flex;
    gap: 44px;
    justify-content: center;
    align-items: center;
  }

  .blog-footer__links p {
    margin: 0;
    font-size: 14px;
  }

  .blog-footer__links a {
    color: var(--fg-primary);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .blog-footer__links a:hover {
    color: var(--fg-link-hover);
  }

  .blog-footer__socials {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    justify-content: center;
  }

  .blog-footer__social-icon {
    width: 24px;
    height: 24px;
    aspect-ratio: 1 / 1;
    display: block;
  }

  .blog-footer__copyright-wrap {
    text-align: center;
  }

  .blog-footer__copyright {
    margin: 0;
    font-size: 14px;
    color: var(--fg-meta);
  }

  @media (min-width: 768px) {
    .blog-footer__top {
      flex-direction: row;
      gap: 44px;
    }

    .blog-footer__socials {
      gap: 44px;
    }
  }
</style>
