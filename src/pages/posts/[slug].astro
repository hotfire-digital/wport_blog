<script is:inline define:vars={clientVars}>
  const READ_POSTS_STORAGE_KEY = "wport.readPosts";
  const SCROLL_THRESHOLDS = [25, 50, 75, 90];
  const READ_COMPLETE_MIN_MS = 30000;
  const firedScrollDepths = new Set();
  const pageOpenedAt = Date.now();
  let readCompleteSent = false;

  const postContext = {
    post_id: postId,
    post_title: postTitle,
    post_tags: postTags,
    publish_date: publishDate,
    page_type: "post_detail",
  };

  function pushEvent(event, payload) {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push(Object.assign({ event: event }, postContext, payload || {}));
  }

  function readStoredPostIds() {
    try {
      const raw = window.localStorage.getItem(READ_POSTS_STORAGE_KEY);
      if (!raw) return [];
      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed)) return [];
      return parsed.filter(function (value) {
        return typeof value === "string" && value.length > 0;
      });
    } catch {
      return [];
    }
  }

  function markPostAsReadLocally(id) {
    const existing = readStoredPostIds();
    if (existing.indexOf(id) !== -1) return false;
    existing.push(id);
    window.localStorage.setItem(READ_POSTS_STORAGE_KEY, JSON.stringify(existing));
    return true;
  }

  function showReadBadge() {
    var titleEl = document.querySelector(".post-title") || document.querySelector("h1");
    if (!titleEl || document.getElementById("post-read-badge")) return;
    var badge = document.createElement("span");
    badge.id = "post-read-badge";
    badge.className = "read-badge read-badge--inline";
    badge.textContent = "已閱讀";
    titleEl.insertAdjacentElement("afterend", badge);
  }

  function maybeCompleteRead(scrollPercent) {
    if (readCompleteSent) return;
    if (scrollPercent < 90) return;
    if (Date.now() - pageOpenedAt < READ_COMPLETE_MIN_MS) return;

    readCompleteSent = true;
    pushEvent("read_complete", { scroll_percent: 90 });

    var isFirstMark = markPostAsReadLocally(postId);
    showReadBadge();
    if (isFirstMark) {
      pushEvent("mark_read", { scroll_percent: 90 });
    }
  }

  pushEvent("post_view");
  if (readStoredPostIds().indexOf(postId) !== -1) {
    showReadBadge();
  }

  // 閱讀進度條
  const sidebarFill = document.getElementById("sidebar-progress-fill");
  const progressPct = document.getElementById("progress-pct");
  const backToTop = document.getElementById("back-to-top");

  function updateProgress() {
    const el = document.documentElement;
    const pct =
      el.scrollHeight - el.clientHeight > 0
        ? (el.scrollTop / (el.scrollHeight - el.clientHeight)) * 100
        : 0;
    const w = pct.toFixed(1) + "%";
    if (sidebarFill) sidebarFill.style.width = w;
    if (progressPct) progressPct.textContent = Math.round(pct) + "%";
    if (backToTop) backToTop.style.display = pct > 5 ? "flex" : "none";

    SCROLL_THRESHOLDS.forEach(function (threshold) {
      if (pct >= threshold && !firedScrollDepths.has(threshold)) {
        firedScrollDepths.add(threshold);
        pushEvent("scroll_depth", { scroll_percent: threshold });
      }
    });

    maybeCompleteRead(pct);
  }

  window.addEventListener("scroll", updateProgress, { passive: true });
  updateProgress();

  // 回到頂部
  if (backToTop) {
    backToTop.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
  }

  // TOC 自動產生
  const toc = document.getElementById("toc");
  const headings = document.querySelectorAll(".prose h2, .prose h3");
  if (toc && headings.length > 0) {
    headings.forEach((h, idx) => {
      const id = "heading-" + idx;
      h.id = id;
      const a = document.createElement("a");
      a.href = "#" + id;
      a.className = "toc-link" + (h.tagName === "H3" ? " h3" : "");
      a.textContent = h.textContent || "";
      a.addEventListener("click", (e) => {
        e.preventDefault();
        h.scrollIntoView({ behavior: "smooth", block: "start" });
      });
      toc.appendChild(a);
    });

    // Active section highlight: choose the closest heading above viewport anchor.
    const tocLinks = Array.from(toc.querySelectorAll(".toc-link"));
    const setActiveHeading = () => {
      const anchorY = window.scrollY + 140;
      let activeIndex = 0;

      headings.forEach((heading, index) => {
        if (heading.offsetTop <= anchorY) {
          activeIndex = index;
        }
      });

      tocLinks.forEach((link, index) => {
        link.classList.toggle("active", index === activeIndex);
      });
    };

    window.addEventListener("scroll", setActiveHeading, { passive: true });
    setActiveHeading();
  }

  // Toast helper
  function showToast(msg) {
    const toast = document.getElementById("toast");
    if (!toast) return;
    toast.textContent = msg;
    toast.style.opacity = "1";
    setTimeout(() => {
      toast.style.opacity = "0";
    }, 2000);
  }

  const copyIconSvg =
    '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';

  function enhanceCodeBlocks() {
    const pres = document.querySelectorAll(".prose pre");
    pres.forEach((pre) => {
      if (pre.closest(".code-block")) return;

      const wrapper = document.createElement("div");
      wrapper.className = "code-block";
      pre.parentNode.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "code-block-copy";
      btn.setAttribute("aria-label", "複製程式碼");
      btn.innerHTML = copyIconSvg + '<span>複製</span>';

      const label = btn.querySelector("span");

      btn.addEventListener("click", async () => {
        const text = (pre.textContent || "").replace(/\n$/, "");
        try {
          await navigator.clipboard.writeText(text);
          btn.classList.add("is-copied");
          if (label) label.textContent = "已複製";
          showToast("已複製到剪貼簿");
          window.setTimeout(() => {
            btn.classList.remove("is-copied");
            if (label) label.textContent = "複製";
          }, 2000);
        } catch {
          showToast("複製失敗，請手動選取");
        }
      });

      wrapper.appendChild(btn);
    });
  }

  enhanceCodeBlocks();

  // 複製連結 / 分享追蹤
  document.querySelectorAll("[data-share-platform]").forEach(function (el) {
    el.addEventListener("click", function () {
      var platform = el.getAttribute("data-share-platform") || "unknown";
      pushEvent("share_click", { share_platform: platform });
    });
  });

  document.getElementById("copy-link-btn")?.addEventListener("click", () => {
    navigator.clipboard.writeText(shareUrl).then(() => showToast("已複製連結"));
  });

  document.getElementById("share-instagram-btn")?.addEventListener("click", () => {
    navigator.clipboard.writeText(shareUrl).then(() => {
      showToast("已複製連結，請貼到 Instagram");
      window.open("https://www.instagram.com/", "_blank", "noopener,noreferrer");
    });
  });

  document.querySelectorAll("[data-related-post-id]").forEach(function (el) {
    el.addEventListener("click", function () {
      var targetId = el.getAttribute("data-related-post-id") || "";
      pushEvent("related_post_click", { target_post_id: targetId });
    });
  });

  // AI 友善複製（格式分段 + 圖示橫排）
  const aiCopyFormats = {
    md: {
      label: "Markdown",
      path: rawMdPath,
      url: rawMdUrl,
      openTitle: "在新分頁開啟 Markdown 原文",
      urlTitle: "複製 Markdown 連結",
      contentTitle: "複製 Markdown 全文",
      openAria: "開啟 Markdown 原文",
      urlAria: "複製 Markdown 連結",
      contentAria: "複製 Markdown 全文",
      copyToast: "已複製 Markdown 全文",
      urlToast: "已複製 MD 連結",
      copyLabel: "Copy as MD",
    },
    json: {
      label: "JSON",
      path: rawJsonPath,
      url: rawJsonUrl,
      openTitle: "在新分頁開啟 JSON 原文",
      urlTitle: "複製 JSON 連結",
      contentTitle: "複製 JSON 全文",
      openAria: "開啟 JSON 原文",
      urlAria: "複製 JSON 連結",
      contentAria: "複製 JSON 全文",
      copyToast: "已複製 JSON 全文",
      urlToast: "已複製 JSON 連結",
      copyLabel: "Copy as JSON",
    },
  };

  const aiCopyPanel = document.getElementById("ai-copy-panel");
  const aiCopySegment = document.querySelector(".ai-copy-segment");
  const aiCopyOpen = document.getElementById("ai-copy-open");
  const aiCopyUrlBtn = document.getElementById("ai-copy-url-btn");
  const aiCopyContentBtn = document.getElementById("ai-copy-content-btn");
  const aiCopyContentLabel = document.getElementById("ai-copy-content-label");
  const aiCopySegmentBtns = document.querySelectorAll(".ai-copy-segment-btn");
  let selectedAiCopyFormat = aiCopyFormats.md;
  let aiCopyFormatInitialized = false;

  function applyAiCopyFormat(key) {
    const format = key === "json" ? aiCopyFormats.json : aiCopyFormats.md;
    selectedAiCopyFormat = format;

    aiCopySegmentBtns.forEach((btn) => {
      const isActive = btn.getAttribute("data-format") === key;
      btn.classList.toggle("is-active", isActive);
      btn.setAttribute("aria-selected", String(isActive));
    });

    aiCopySegment?.setAttribute("data-active", key);

    if (aiCopyOpen) {
      aiCopyOpen.href = format.path;
      aiCopyOpen.title = format.openTitle;
      aiCopyOpen.setAttribute("aria-label", format.openAria);
    }
    if (aiCopyUrlBtn) {
      aiCopyUrlBtn.title = format.urlTitle;
      aiCopyUrlBtn.setAttribute("aria-label", format.urlAria);
    }
    if (aiCopyContentBtn) {
      aiCopyContentBtn.title = format.contentTitle;
      aiCopyContentBtn.setAttribute("aria-label", format.contentAria);
    }
    if (aiCopyContentLabel) {
      if (aiCopyFormatInitialized) {
        aiCopyContentLabel.style.opacity = "0";
        window.setTimeout(() => {
          aiCopyContentLabel.textContent = format.copyLabel;
          aiCopyContentLabel.style.opacity = "1";
        }, 100);
      } else {
        aiCopyContentLabel.textContent = format.copyLabel;
      }
    }

    aiCopyFormatInitialized = true;
  }

  aiCopyPanel?.addEventListener("click", (event) => {
    const segmentBtn = event.target.closest(".ai-copy-segment-btn");
    if (!segmentBtn) return;

    const key = segmentBtn.getAttribute("data-format");
    if (key === "md" || key === "json") {
      applyAiCopyFormat(key);
    }
  });

  applyAiCopyFormat("md");

  aiCopyUrlBtn?.addEventListener("click", () => {
    navigator.clipboard.writeText(selectedAiCopyFormat.url).then(() => {
      showToast(selectedAiCopyFormat.urlToast);
    });
  });

  aiCopyContentBtn?.addEventListener("click", async () => {
    if (!aiCopyContentBtn) return;
    aiCopyContentBtn.disabled = true;
    try {
      const res = await fetch(selectedAiCopyFormat.path);
      if (!res.ok) throw new Error("fetch failed");
      const text = await res.text();
      await navigator.clipboard.writeText(text);
      showToast(selectedAiCopyFormat.copyToast);
    } catch {
      showToast("複製失敗，請稍後再試");
    } finally {
      aiCopyContentBtn.disabled = false;
    }
  });

  // 文章內職缺推薦（第二個 H2 前的 slot）。每篇文章依 frontmatter 決定來源：
  //   有 jobKeywords → 一般職缺搜尋（依主題關鍵字）
  //   否則 tag 有「僑外生」→ 僑外生 zone（每次進頁隨機取樣）
  //   都沒有 → 隱藏（不推不相關的職缺）
  (function initJobRecommendations() {
    const slot = document.querySelector(".job-recs-slot");
    if (!slot) return;

    const keywords = (jobKeywords || "")
      .split(",")
      .map((kw) => kw.trim())
      .filter(Boolean);
    const tags = (postTags || "")
      .split(",")
      .map((t) => t.trim())
      .filter(Boolean);

    const base = jobsApiBase.replace(/\/$/, "");

    function buildLogo(job) {
      const name = job.company_name || "";
      if (job.company_logo_url) {
        const img = document.createElement("img");
        img.className = "job-rec-logo";
        img.src = job.company_logo_url;
        img.alt = name ? name + " logo" : "";
        img.loading = "lazy";
        img.decoding = "async";
        img.addEventListener("error", () => {
          img.replaceWith(buildLogoFallback(name));
        });
        return img;
      }
      return buildLogoFallback(name);
    }

    function buildLogoFallback(name) {
      const fallback = document.createElement("div");
      fallback.className = "job-rec-logo job-rec-logo-fallback";
      fallback.textContent = (name.trim()[0] || "職").toUpperCase();
      return fallback;
    }

    function buildCard(job, position, keyword) {
      const card = document.createElement("a");
      card.className = "job-rec-card";
      card.href = jobDetailUrl.replace("{enc_id}", encodeURIComponent(job.enc_id || ""));
      card.target = "_blank";
      card.rel = "noopener";

      card.appendChild(buildLogo(job));

      const body = document.createElement("div");
      body.className = "job-rec-body";

      const title = document.createElement("p");
      title.className = "job-rec-title";
      title.textContent = job.title || "";
      body.appendChild(title);

      if (job.company_name) {
        const company = document.createElement("p");
        company.className = "job-rec-company";
        company.textContent = job.company_name;
        body.appendChild(company);
      }

      // Location trimmed to city + district only (drop street / landmark detail).
      const district = (job.area_display || "").split(/\s/)[0];
      if (district) {
        const loc = document.createElement("p");
        loc.className = "job-rec-loc";
        loc.innerHTML =
          '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>';
        loc.appendChild(document.createTextNode(district));
        body.appendChild(loc);
      }

      card.appendChild(body);

      card.addEventListener("click", () => {
        pushEvent("recommended_job_click", {
          job_id: job.enc_id || "",
          job_title: job.title || "",
          job_company: job.company_name || "",
          job_position: position,
          job_keyword: keyword || "",
        });
      });

      return card;
    }

    // opts: { heading, subtitle, moreText, moreHref, keyword }
    function render(jobs, opts) {
      const section = document.createElement("div");
      section.className = "job-recs";

      const header = document.createElement("div");
      header.className = "job-recs-header";
      const heading = document.createElement("h2");
      heading.className = "job-recs-title";
      heading.textContent = opts.heading;
      const subtitle = document.createElement("span");
      subtitle.className = "job-recs-subtitle";
      subtitle.textContent = opts.subtitle;
      header.appendChild(heading);
      header.appendChild(subtitle);
      section.appendChild(header);

      const list = document.createElement("ul");
      list.className = "job-recs-list";
      jobs.forEach((job, index) => {
        const li = document.createElement("li");
        li.className = "job-rec-item";
        li.appendChild(buildCard(job, index + 1, opts.keyword));
        list.appendChild(li);
      });
      section.appendChild(list);

      const more = document.createElement("a");
      more.className = "job-recs-more";
      more.href = opts.moreHref;
      more.target = "_blank";
      more.rel = "noopener";
      more.textContent = opts.moreText;
      more.addEventListener("click", () => {
        pushEvent("recommended_jobs_search_click", { job_keyword: opts.keyword || "" });
      });
      section.appendChild(more);

      slot.textContent = "";
      slot.appendChild(section);
      slot.removeAttribute("hidden");

      pushEvent("recommended_jobs_view", { jobs_count: jobs.length, job_keyword: opts.keyword || "" });
    }

    // Fisher-Yates shuffle so each page view surfaces a different sample.
    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i -= 1) {
        const j = Math.floor(Math.random() * (i + 1));
        const tmp = arr[i];
        arr[i] = arr[j];
        arr[j] = tmp;
      }
      return arr;
    }

    // Keep at most one job per company so a single recruiter cannot flood the grid.
    function dedupeByCompany(pool, limit) {
      const seen = new Set();
      const result = [];
      for (const job of pool) {
        const key = job.enc_company_id || job.company_name || "";
        if (key && seen.has(key)) continue;
        seen.add(key);
        result.push(job);
        if (result.length >= limit) break;
      }
      return result;
    }

    function pick(pool) {
      return dedupeByCompany(shuffle(pool.slice()), 6);
    }

    function fetchJobs(url) {
      return fetch(url, { headers: { Accept: "application/json" } })
        .then((res) => (res.ok ? res.json() : null))
        .then((json) => (json && Array.isArray(json.data) ? json.data : []));
    }

    // Mode 1: general job search by the post's jobKeywords (topic-relevant).
    function tryKeyword(index) {
      if (index >= keywords.length) return;
      const keyword = keywords[index];
      const url = base + "/jobs/search?keyword=" + encodeURIComponent(keyword) + "&pageSize=30";
      fetchJobs(url)
        .then((pool) => {
          const jobs = pick(pool);
          if (jobs.length > 0) {
            render(jobs, {
              heading: "相關職缺推薦",
              subtitle: "為你精選「" + keyword + "」職缺",
              moreText: "看更多「" + keyword + "」職缺 →",
              moreHref: jobSearchUrl.replace("{kw}", encodeURIComponent(keyword)),
              keyword: keyword,
            });
          } else {
            tryKeyword(index + 1);
          }
        })
        .catch(() => tryKeyword(index + 1));
    }

    // Mode 2: foreign-student zone (default for 僑外生 posts), random sample.
    function loadZone() {
      fetchJobs(base + "/overseas-student-zone/jobs?pageSize=50")
        .then((pool) => {
          const jobs = pick(pool);
          if (jobs.length > 0) {
            render(jobs, {
              heading: "僑外生職缺推薦",
              subtitle: "精選在台僑外生友善職缺",
              moreText: "看更多僑外生職缺 →",
              moreHref: jobZoneUrl,
              keyword: "",
            });
          }
        })
        .catch(() => {
          // 靜默降級：區塊維持 hidden
        });
    }

    if (keywords.length > 0) {
      tryKeyword(0);
    } else if (tags.indexOf("僑外生") !== -1) {
      loadZone();
    }
    // else: no keywords and not a 僑外生 post → leave the section hidden.
  })();
</script>
