---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import Topbar from "@/components/Topbar.astro";
import CoverImage from "@/components/CoverImage.astro";
import { getCoverImageUrls } from "@/lib/cover-image";
import { getPostViews, formatPostViews } from "@/lib/post-views";
import { getJobsConfig } from "@/lib/analytics";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post: CollectionEntry<"posts">) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
const { Content } = await render(post);
const allPosts = await getCollection("posts", ({ data }) => !data.draft);

const sortedPosts = [...allPosts].sort(
  (a: CollectionEntry<"posts">, b: CollectionEntry<"posts">) =>
    b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const currentIndex = sortedPosts.findIndex((entry) => entry.id === post.id);
const previousPost = currentIndex >= 0 && currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const currentTags = new Set(post.data.tags ?? []);
const relatedPosts = sortedPosts
  .filter((entry) => entry.id !== post.id)
  .map((entry) => {
    const tags = entry.data.tags ?? [];
    const sharedTagCount = tags.filter((tag) => currentTags.has(tag)).length;
    return { entry, sharedTagCount };
  })
  .sort((a, b) => {
    if (b.sharedTagCount !== a.sharedTagCount) {
      return b.sharedTagCount - a.sharedTagCount;
    }
    return b.entry.data.publishDate.getTime() - a.entry.data.publishDate.getTime();
  })
  .slice(0, 3)
  .map((item) => item.entry);

const shareUrl = `https://wport.me/blog/posts/${post.id}/`;
const shareUrlEncoded = encodeURIComponent(shareUrl);
const shareTitle = encodeURIComponent(post.data.title);
const shareText = encodeURIComponent(`${post.data.title}｜Wport Blog`);
const baseUrl = import.meta.env.BASE_URL;
const normalizedBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const rawMdPath = withBase(`/posts/${post.id}.md`);
const rawMdUrl = `https://wport.me/blog/posts/${post.id}.md`;
const rawJsonPath = withBase(`/posts/${post.id}.json`);
const rawJsonUrl = `https://wport.me/blog/posts/${post.id}.json`;

const jobsConfig = getJobsConfig();
const jobKeywords = (post.data.jobKeywords ?? []).filter((kw) => kw && kw.trim());

const clientVars = {
  shareUrl,
  rawMdPath,
  rawMdUrl,
  rawJsonPath,
  rawJsonUrl,
  postId: post.id,
  postTitle: post.data.title,
  postTags: (post.data.tags ?? []).join(","),
  publishDate: post.data.publishDate.toISOString().slice(0, 10),
  jobKeywords: jobKeywords.join(","),
  jobsApiBase: jobsConfig.apiBase,
  jobDetailUrl: jobsConfig.detailUrl,
  jobSearchUrl: jobsConfig.searchUrl,
  jobZoneUrl: jobsConfig.zoneUrl,
};

const heroCover = post.data.cover ? getCoverImageUrls(post.data.cover, "prose") : undefined;
const postViews = getPostViews(post.id);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  cover={post.data.cover}
  publishDate={post.data.publishDate}
  tags={post.data.tags}
  canonicalUrl={shareUrl}
>
  <Fragment slot="head">
    <link rel="alternate" type="text/markdown" href={rawMdUrl} title="Markdown 原文（AI 友善）" />
    {
      heroCover && (
        <link
          rel="preload"
          as="image"
          href={heroCover.default}
          imagesrcset={heroCover.srcset}
          imagesizes={heroCover.sizes}
          fetchpriority="high"
        />
      )
    }
  </Fragment>
  <Topbar />

  <main class="post-main">
    <a href={withBase("/")} class="back-link">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      返回文章列表
    </a>

    <div class="post-layout">
      <!-- 主內容 -->
      <article>
        <header class="post-header">
          <div class="post-tags">
            {
              post.data.tags &&
                post.data.tags.slice(0, 4).map((tag: string) => (
                  <a href={`${withBase("/archive")}?tag=${encodeURIComponent(tag)}`} class="tag">
                    {tag}
                  </a>
                ))
            }
          </div>
          <h1 class="post-title">
            {post.data.title}
          </h1>
          <div class="post-meta-row">
            <span class="post-meta-date">
              {
                post.data.publishDate.toLocaleDateString("zh-TW", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })
              }
            </span>
            {
              postViews > 0 && (
                <>
                  <span class="post-meta-sep" aria-hidden="true">
                    ·
                  </span>
                  <span class="post-meta-views">{formatPostViews(postViews)}</span>
                </>
              )
            }
          </div>
          <p class="post-description">
            {post.data.description}
          </p>
        </header>

        <div class="prose">
          <Content />
        </div>

        {
          relatedPosts.length > 0 && (
            <section class="post-related">
              <h2 class="post-related-title">相關文章</h2>
              <ul class="post-related-list">
                {relatedPosts.map((related) => {
                  const relatedViews = getPostViews(related.id);
                  return (
                    <li>
                      <a
                        href={withBase(`/posts/${related.id}`)}
                        class:list={["post-related-card", !related.data.cover && "post-related-card--no-cover"]}
                        data-related-post-id={related.id}
                      >
                        {related.data.cover && (
                          <CoverImage
                            src={related.data.cover}
                            alt={`${related.data.title} cover`}
                            class="post-related-cover"
                            context="thumbnail"
                            loading="lazy"
                          />
                        )}
                        <div class="post-related-content">
                          <div class="post-related-card-title">{related.data.title}</div>
                          <p class="post-related-card-description">{related.data.description}</p>
                          <div class="post-related-card-meta">
                            <span class="post-related-card-date">
                              {related.data.publishDate.toLocaleDateString("zh-TW", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                              })}
                            </span>
                            {relatedViews > 0 && (
                              <>
                                <span class="post-related-card-sep" aria-hidden="true">
                                  ·
                                </span>
                                <span class="post-related-card-views">{formatPostViews(relatedViews)}</span>
                              </>
                            )}
                          </div>
                        </div>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </section>
          )
        }

        {
          (previousPost || nextPost) && (
            <nav class="post-pagination" aria-label="文章導覽">
              <div class="post-pagination-item">
                {previousPost && (
                  <a href={withBase(`/posts/${previousPost.id}`)} class="post-pagination-link">
                    {previousPost.data.cover && (
                      <CoverImage
                        src={previousPost.data.cover}
                        alt={`${previousPost.data.title} cover`}
                        class="post-pagination-cover"
                        context="thumbnail"
                        loading="lazy"
                      />
                    )}
                    <span class="post-pagination-label">上一篇</span>
                    <span class="post-pagination-title">{previousPost.data.title}</span>
                  </a>
                )}
              </div>
              <div class="post-pagination-item post-pagination-item-next">
                {nextPost && (
                  <a href={withBase(`/posts/${nextPost.id}`)} class="post-pagination-link">
                    {nextPost.data.cover && (
                      <CoverImage
                        src={nextPost.data.cover}
                        alt={`${nextPost.data.title} cover`}
                        class="post-pagination-cover"
                        context="thumbnail"
                        loading="lazy"
                      />
                    )}
                    <span class="post-pagination-label">下一篇</span>
                    <span class="post-pagination-title">{nextPost.data.title}</span>
                  </a>
                )}
              </div>
            </nav>
          )
        }
      </article>

      <!-- 側邊欄 -->
      <aside class="sidebar">
        <!-- 閱讀進度 -->
        <div class="sidebar-card sidebar-card-toc">
          <div class="sidebar-progress-bar">
            <div id="sidebar-progress-fill" class="sidebar-progress-fill"></div>
          </div>
          <div class="sidebar-card-header">
            <span class="sidebar-label">目錄</span>
            <span id="progress-pct" class="sidebar-progress-pct">0%</span>
          </div>
          <nav id="toc" class="toc"></nav>
        </div>

        <!-- AI 友善複製 -->
        <div class="sidebar-card" id="ai-copy-panel">
          <div class="sidebar-label sidebar-section-label">AI 友善複製</div>
          <div class="ai-copy-body">
            <div class="ai-copy-segment" role="tablist" aria-label="選擇格式" data-active="md">
              <span class="ai-copy-segment-indicator" aria-hidden="true"></span>
              <button
                type="button"
                class="ai-copy-segment-btn is-active"
                role="tab"
                data-format="md"
                aria-selected="true"
              >
                MD
              </button>
              <button type="button" class="ai-copy-segment-btn" role="tab" data-format="json" aria-selected="false">
                JSON
              </button>
            </div>
            <div class="ai-copy-action-row">
              <a
                class="ai-copy-icon-btn ai-copy-icon-btn-primary"
                id="ai-copy-open"
                href={rawMdPath}
                target="_blank"
                rel="noopener"
                title="在新分頁開啟 Markdown 原文"
                aria-label="開啟 Markdown 原文"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
                <span class="ai-copy-icon-btn-label">Open</span>
              </a>
              <button
                type="button"
                class="ai-copy-icon-btn"
                id="ai-copy-url-btn"
                title="複製 Markdown 連結"
                aria-label="複製 Markdown 連結"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                </svg>
                <span class="ai-copy-icon-btn-label">Copy URL</span>
              </button>
              <button
                type="button"
                class="ai-copy-icon-btn"
                id="ai-copy-content-btn"
                title="複製 Markdown 全文"
                aria-label="複製 Markdown 全文"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <span class="ai-copy-icon-btn-label ai-copy-content-label" id="ai-copy-content-label">Copy as MD</span>
              </button>
            </div>
          </div>
        </div>

        <!-- 分享 -->
        <div class="sidebar-card">
          <div class="sidebar-label sidebar-section-label">分享</div>
          <div class="share-row">
            <a
              href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrlEncoded}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn"
              data-share-platform="x"
              title="分享到 X"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117Z"
                ></path>
              </svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrlEncoded}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn"
              data-share-platform="linkedin"
              title="分享到 LinkedIn"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </a>
            <a
              href={`https://social-plugins.line.me/lineit/share?url=${shareUrlEncoded}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn"
              data-share-platform="line"
              title="分享到 LINE"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M20.4 10.8c0-4.5-4.2-8.2-9.4-8.2S1.6 6.3 1.6 10.8c0 4 3.3 7.4 7.7 8l-.3 2.5c0 .2.1.3.3.2l2.9-2.1h.8c5.2 0 9.4-3.7 9.4-8.2zm-13.9.4H5V8.4c0-.3.2-.5.5-.5s.5.2.5.5v2.3h.5c.3 0 .5.2.5.5s-.2.5-.5.5zm2.9.5c0 .3-.2.5-.5.5s-.5-.2-.5-.5V8.4c0-.3.2-.5.5-.5s.5.2.5.5v3.3zm3 0c0 .2-.1.4-.3.5-.2.1-.4 0-.6-.1l-1.5-2v1.6c0 .3-.2.5-.5.5s-.5-.2-.5-.5V8.4c0-.2.1-.4.3-.5.2-.1.4 0 .6.1l1.5 2V8.4c0-.3.2-.5.5-.5s.5.2.5.5v3.3zm2.8-2.8h-1.4v.5h1.1c.3 0 .5.2.5.5s-.2.5-.5.5h-1.1v.5h1.4c.3 0 .5.2.5.5s-.2.5-.5.5h-1.9c-.3 0-.5-.2-.5-.5V8.4c0-.3.2-.5.5-.5h1.9c.3 0 .5.2.5.5s-.2.5-.5.5z"
                ></path>
              </svg>
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrlEncoded}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn"
              data-share-platform="facebook"
              title="分享到 Facebook"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.019 4.388 11.008 10.125 11.927v-8.437H7.078v-3.49h3.047V9.413c0-3.017 1.792-4.686 4.533-4.686 1.313 0 2.686.236 2.686.236v2.962h-1.514c-1.491 0-1.956.93-1.956 1.885v2.263h3.328l-.532 3.49h-2.796V24C19.612 23.081 24 18.092 24 12.073z"
                ></path>
              </svg>
            </a>
            <a
              href={`https://www.threads.net/intent/post?text=${shareText}%20${shareUrlEncoded}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn"
              data-share-platform="threads"
              title="分享到 Threads"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M16.3 11.7c-.2 0-.4 0-.5.1-.1-2.3-1.4-3.6-3.7-3.6-2.1 0-3.6 1.2-3.9 3.1l1.8.5c.2-1.1.9-1.8 2-1.8 1.2 0 1.9.7 2 2-.7.2-1.6.4-2.5.6-2.2.5-3.3 1.5-3.3 3.1 0 1.9 1.5 3.2 3.6 3.2 1.9 0 3.1-.8 3.7-2.2.3-.8.4-1.8.3-2.9.1 0 .2 0 .4-.1.9-.2 1.4-.7 1.4-1.4s-.5-1.2-1.3-1.4zm-2.2 3.8c-.3.9-1 1.4-2 1.4-.9 0-1.6-.5-1.6-1.2 0-.6.4-1 1.6-1.3.7-.2 1.4-.4 2-.5.1.7.1 1.2 0 1.6zM12 .8C5.8.8.8 5.8.8 12S5.8 23.2 12 23.2 23.2 18.2 23.2 12 18.2.8 12 .8zM12 21.2C6.9 21.2 2.8 17.1 2.8 12S6.9 2.8 12 2.8 21.2 6.9 21.2 12 17.1 21.2 12 21.2z"
                ></path>
              </svg>
            </a>
            <button class="share-btn" id="share-instagram-btn" data-share-platform="instagram" title="分享到 Instagram">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2zm8.2 1.8H8A4.2 4.2 0 0 0 3.8 8v8a4.2 4.2 0 0 0 4.2 4.2h8a4.2 4.2 0 0 0 4.2-4.2V8A4.2 4.2 0 0 0 16 3.8zm-4 3.1a5.1 5.1 0 1 1 0 10.2 5.1 5.1 0 0 1 0-10.2zm0 1.8a3.3 3.3 0 1 0 0 6.6 3.3 3.3 0 0 0 0-6.6zm5.6-.9a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4z"
                ></path>
              </svg>
            </button>
            <button class="share-btn" id="copy-link-btn" data-share-platform="copy_link" title="複製連結">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
              </svg>
            </button>
          </div>
        </div>
      </aside>
    </div>
  </main>

  <!-- Toast -->
  <div id="toast" class="post-toast"></div>

  <!-- 回到頂部 -->
  <button id="back-to-top" class="back-to-top-btn" title="回到最上方">
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="18 15 12 9 6 15"></polyline>
    </svg>
  </button>
</BlogLayout>

<style is:global>
  .post-main {
    max-width: 1080px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    color: var(--fg-meta);
    text-decoration: none;
    margin-bottom: var(--space-8);
    transition: color var(--transition-base);
  }
  .back-link:hover {
    color: var(--fg-link-hover);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }
  .tag {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-primary);
    background: var(--bg-tag);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
  }
  .post-header {
    margin-bottom: 36px;
  }
  .post-title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--fg-heading);
    line-height: var(--leading-tight);
    margin-bottom: 14px;
  }
  .post-description {
    font-size: var(--text-base);
    color: var(--fg-meta);
    line-height: 1.7;
    margin-bottom: 20px;
  }
  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 0;
  }
  .post-meta-date,
  .post-meta-views {
    font-size: var(--text-sm);
    color: var(--fg-meta);
  }
  .post-meta-sep {
    color: var(--fg-meta);
    opacity: 0.5;
  }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 40px;
    align-items: start;
  }

  .sidebar {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sidebar-card {
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    padding: 14px 16px;
  }
  .sidebar-card-toc {
    overflow: hidden;
  }

  .sidebar-progress-bar {
    height: 3px;
    background: var(--bg-code);
    margin: -14px -16px 14px;
    border-radius: 2px 2px 0 0;
  }
  .sidebar-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    transition: width 80ms linear;
    border-radius: 2px;
  }

  .sidebar-card-header {
    display: flex;
