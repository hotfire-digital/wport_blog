---
import { getCollection, type CollectionEntry } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import Topbar from "@/components/Topbar.astro";
import CoverImage from "@/components/CoverImage.astro";
import { getCoverImageUrls } from "@/lib/cover-image";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a: CollectionEntry<"posts">, b: CollectionEntry<"posts">) =>
    b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const featured = sorted.filter((p) => p.data.featured).slice(0, 3);
const popular = featured.length > 0 ? featured : sorted.slice(0, 3);
const tagCountMap = sorted.reduce((acc, post) => {
  for (const tag of post.data.tags ?? []) {
    acc.set(tag, (acc.get(tag) ?? 0) + 1);
  }
  return acc;
}, new Map<string, number>());
const tagOverview = [...tagCountMap.entries()].sort((a, b) => {
  if (b[1] !== a[1]) {
    return b[1] - a[1];
  }
  return a[0].localeCompare(b[0], "zh-Hant");
});

const COVER_COLORS = [
  { hue: "#E0F5F3", accent: "#56C7BB" },
  { hue: "#FEF3E2", accent: "#F59E0B" },
  { hue: "#EEF2FF", accent: "#6366F1" },
  { hue: "#FDF2F8", accent: "#EC4899" },
  { hue: "#F0FDF4", accent: "#22C55E" },
  { hue: "#FFF7ED", accent: "#F97316" },
];
const baseUrl = import.meta.env.BASE_URL;
const normalizedBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const lcpCoverSource = popular[0]?.data.cover;
const lcpCover = lcpCoverSource ? getCoverImageUrls(lcpCoverSource, "card") : undefined;
---

<BlogLayout
  title="Wport Blog — 在台僑外生求學求職完整指南"
  description="專為在台僑外生打造的求學求職資源。涵蓋評點制、AI 課程、實習與工作許可，透過文章學習第一手資訊，提前布局留台職涯。"
>
  {
    lcpCover && (
    <link
      slot="head"
      rel="preload"
      as="image"
      href={lcpCover.default}
      imagesrcset={lcpCover.srcset}
      imagesizes={lcpCover.sizes}
      fetchpriority="high"
    />
    )
  }
  <Topbar currentPage="home" />

  <main>
    <!-- HERO -->
    <section class="hero-section">
      <div class="hero-inner">
        <div class="hero-text">
          <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            專為在台僑外生打造
          </div>
          <h1 class="hero-h1">
            在台僑外生<br />求學求職完整指南
          </h1>
          <h2 class="hero-h2">
            從評點制、AI 課程到實習與工作許可，Wport 彙整第一手資訊與實戰經驗。透過文章學習、掌握政策與職涯策略，讓你在台灣順利學習、求職、留台。
          </h2>
          <div class="hero-ctas">
            <a href={withBase("/archive")} class="btn-primary">瀏覽所有文章 →</a>
            <a href="#popular" class="btn-secondary">熱門文章</a>
          </div>
        </div>
        <div class="hero-art-wrap">
          <div class="hero-figure">
            <img
              src={withBase("/mascot-graduation.png")}
              alt="Wport mascot - graduation"
              class="hero-mascot hero-mascot--graduation"
              width="832"
              height="832"
              decoding="async"
              fetchpriority="high"
            />
            <img
              src={withBase("/mascot-cooperation.png")}
              alt="Wport mascot - cooperation"
              class="hero-mascot hero-mascot--cooperation"
              width="832"
              height="832"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- POPULAR ARTICLES -->
    <section id="popular" class="popular-section">
      <div class="popular-inner">
        <div class="popular-header">
          <div>
            <div class="popular-label">POPULAR</div>
            <h2 class="popular-title">熱門文章</h2>
          </div>
          <a href={withBase("/archive")} class="popular-see-all">查看全部 →</a>
        </div>

        {
          popular.length === 0 ? (
            <p style="color: var(--color-text-muted); font-size: 15px;">目前還沒有文章。</p>
          ) : (
            <ul class="card-grid">
              {popular.map((post, i) => {
                const cover = COVER_COLORS[i % COVER_COLORS.length];
                return (
                  <li>
                    <a href={withBase(`/posts/${post.id}`)} class="card">
                      <div class="card-cover" style={`background: ${cover.hue};`}>
                        {post.data.cover ? (
                          <CoverImage
                            src={post.data.cover}
                            alt={`${post.data.title} cover`}
                            class="card-cover-image"
                            loading={i === 0 ? "eager" : "lazy"}
                            fetchpriority={i === 0 ? "high" : "auto"}
                          />
                        ) : (
                          <>
                            <div class="card-cover-shape1" style={`background: ${cover.accent};`} />
                            <div class="card-cover-shape2" style={`background: ${cover.accent};`} />
                            <div class="card-cover-label" style={`color: ${cover.accent};`}>
                              wport
                            </div>
                          </>
                        )}
                      </div>
                      <div class="card-body">
                        {post.data.tags && post.data.tags.length > 0 && (
                          <div class="card-tags">
                            {post.data.tags.slice(0, 4).map((tag: string) => (
                              <span class="tag">{tag}</span>
                            ))}
                          </div>
                        )}
                        <div class="card-title">{post.data.title}</div>
                        <div class="card-excerpt">{post.data.description}</div>
                        <div class="card-footer">
                          <span class="card-date">
                            {post.data.publishDate.toLocaleDateString("zh-TW", {
                              year: "numeric",
                              month: "long",
                              day: "numeric",
                            })}
                          </span>
                        </div>
                      </div>
                    </a>
                  </li>
                );
              })}
            </ul>
          )
        }
      </div>
    </section>

    <section class="tag-overview-section">
      <div class="tag-overview-inner">
        <div class="popular-header">
          <div>
            <div class="popular-label">TAG OVERVIEW</div>
            <h2 class="popular-title">標籤總覽</h2>
          </div>
        </div>
        {
          tagOverview.length === 0 ? (
            <p style="color: var(--color-text-muted); font-size: 15px;">目前還沒有標籤資料。</p>
          ) : (
            <ul class="tag-overview-list">
              {tagOverview.map(([tag, count]) => (
                <li>
                  <a href={`${withBase("/archive")}?tag=${encodeURIComponent(tag)}`} class="tag-overview-item">
                    <span class="tag-overview-name">{tag}</span>
                    <span class="tag-overview-count">{count}</span>
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </section>
  </main>
</BlogLayout>

<style is:global>
  /* Hero */
  .hero-section {
    background: linear-gradient(180deg, #f8fcfb 0%, #fff 100%);
    border-bottom: 1px solid #f0f0f0;
  }
  .hero-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 64px 24px 72px;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: #0d7c70;
    background: #eaf8f7;
    padding: 5px 12px;
    border-radius: 999px;
    margin-bottom: 20px;
  }
  .hero-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #0d7c70;
    flex-shrink: 0;
  }
  .hero-h1 {
    font-size: 42px;
    font-weight: 700;
    color: #2e2e2e;
    line-height: 1.25;
    margin-bottom: 18px;
    letter-spacing: -0.5px;
    font-family: "PingFang TC", "Noto Sans TC", "Microsoft JhengHei", Arial, sans-serif;
  }
  .hero-h2 {
    font-size: 16px;
    font-weight: 400;
    color: #5d5d5d;
    line-height: 1.75;
    margin-bottom: 28px;
    font-family: "PingFang TC", "Noto Sans TC", "Microsoft JhengHei", Arial, sans-serif;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: #0d7c70;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 12px 22px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 150ms ease;
    font-family: "PingFang TC", "Noto Sans TC", Arial, sans-serif;
    display: inline-block;
  }
  .btn-primary:hover {
    background: #0a6a60;
  }
  .btn-secondary {
    background: #fff;
    color: #5d5d5d;
    border: 1px solid #d7d7d7;
    border-radius: 8px;
    padding: 12px 22px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition:
      border-color 150ms ease,
      color 150ms ease;
    font-family: "PingFang TC", "Noto Sans TC", Arial, sans-serif;
    display: inline-block;
  }
  .btn-secondary:hover {
    border-color: #0d7c70;
    color: #0d7c70;
  }

  .hero-art-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-figure {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1 / 1;
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 20px;
    background: radial-gradient(circle at 50% 45%, #eaf8f7 0%, rgba(248, 247, 247, 0) 68%);
    animation: heroFloat 6s ease-in-out infinite;
    transform-origin: center center;
    filter: drop-shadow(0 16px 32px rgba(86, 199, 187, 0.15));
  }
  .hero-mascot {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    animation: heroCrossfade 8s ease-in-out infinite;
  }
  .hero-mascot--cooperation {
    animation-delay: 4s;
  }
  @keyframes heroFloat {
    0%,
    100% {
      transform: translateY(0px) rotate(-0.5deg);
    }
    35% {
      transform: translateY(-12px) rotate(0.6deg);
    }
    70% {
      transform: translateY(-5px) rotate(-0.3deg);
    }
  }
  @keyframes heroCrossfade {
    0%,
    40% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-figure,
    .hero-mascot {
      animation: none;
    }
    .hero-mascot--graduation {
      opacity: 1;
    }
    .hero-mascot--cooperation {
      opacity: 0;
    }
  }

  /* Popular section */
  .popular-section {
    max-width: 1080px;
    margin: 0 auto;
    padding: 72px 24px 80px;
  }
  .tag-overview-section {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }
  .tag-overview-inner {
    width: 100%;
  }
  .tag-overview-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .tag-overview-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    border: 1px solid #e8e8e8;
    border-radius: 999px;
    padding: 8px 12px;
    background: #fff;
    transition:
      border-color 150ms ease,
      background 150ms ease;
  }
  .tag-overview-item:hover {
    border-color: #0d7c70;
    background: #f8fcfb;
  }
  .tag-overview-name {
    font-size: 13px;
    color: #2e2e2e;
    font-weight: 500;
  }
  .tag-overview-count {
    font-size: 12px;
    color: #0d7c70;
    font-weight: 700;
    background: #eaf8f7;
    border-radius: 999px;
    padding: 2px 7px;
    min-width: 22px;
    text-align: center;
  }
  .popular-inner {
    width: 100%;
  }
  .popular-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 32px;
  }
  .popular-label {
    font-size: 12px;
    font-weight: 600;
    color: #0d7c70;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    font-family: "PingFang TC", "Noto Sans TC", Arial, sans-serif;
  }
  .popular-title {
    font-size: 28px;
    font-weight: 700;
    color: #2e2e2e;
    line-height: 1.3;
    font-family: "PingFang TC", "Noto Sans TC", Arial, sans-serif;
  }
  .popular-see-all {
    color: #0d7c70;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: color 150ms ease;
    font-family: "PingFang TC", "Noto Sans TC", Arial, sans-serif;
  }
  .popular-see-all:hover {
    color: #0a6a60;
  }

  /* Cards (shared with archive) */
  .card-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }
  .card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 12px;
    border: 1px solid #e8e8e8;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      box-shadow 180ms ease,
      transform 180ms ease;
  }
  .card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.09);
    transform: translateY(-2px);
  }
  .card-cover {
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .card-cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card-cover-shape1 {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    opacity: 0.18;
    position: absolute;
    top: 28px;
    left: 28px;
  }
  .card-cover-shape2 {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    opacity: 0.25;
    position: absolute;
    bottom: 20px;
    right: 36px;
  }
  .card-cover-label {
    font-size: 36px;
    font-weight: 700;
    opacity: 0.22;
    user-select: none;
    letter-spacing: -2px;
  }
  .card-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    font-size: 11px;
    font-weight: 500;
    color: #0d7c70;
    background: #eaf8f7;
    border-radius: 999px;
    padding: 2px 8px;
  }
  .card-title {
    font-size: 16px;
    font-weight: 700;
    color: #2e2e2e;
    line-height: 1.4;
  }
  .card-excerpt {
    font-size: 13.5px;
    color: var(--color-text-muted);
    line-height: 1.65;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    padding-top: 8px;
    border-top: 1px solid #f0f0f0;
  }
  .card-date {
    font-size: 12px;
    color: var(--color-text-faint);
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-art-wrap {
      display: none;
    }
    .hero-h1 {
      font-size: 30px;
    }
  }
</style>
