---
import { getCollection, type CollectionEntry } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import Topbar from "@/components/Topbar.astro";
import ArticleArchive from "@/components/ArticleArchive";

const posts = (await getCollection("posts")).sort(
  (a: CollectionEntry<"posts">, b: CollectionEntry<"posts">) =>
    b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const COVER_COLORS = [
  { hue: "#E0F5F3", accent: "#56C7BB" },
  { hue: "#FEF3E2", accent: "#F59E0B" },
  { hue: "#EEF2FF", accent: "#6366F1" },
  { hue: "#FDF2F8", accent: "#EC4899" },
  { hue: "#F0FDF4", accent: "#22C55E" },
  { hue: "#FFF7ED", accent: "#F97316" },
];

const postsData = posts.map((post, i) => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  publishDate: post.data.publishDate.toISOString(),
  tags: post.data.tags ?? [],
  coverHue: COVER_COLORS[i % COVER_COLORS.length].hue,
  coverAccent: COVER_COLORS[i % COVER_COLORS.length].accent,
}));

const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
---

<BlogLayout title="所有文章 — Wport Blog">
  <Topbar currentPage="archive" />

  <main style="max-width: 1080px; margin: 0 auto; padding: 48px 24px 80px;">
    <header style="margin-bottom: 40px;">
      <h1
        style="font-size: 34px; font-weight: 700; color: #2E2E2E; line-height: 1.25; margin-bottom: 10px; font-family: 'PingFang TC','Noto Sans TC',Arial,sans-serif;"
      >
        所有文章
      </h1>
      <p
        style="font-size: 15px; color: #9A9A9A; line-height: 1.7; font-family: 'PingFang TC','Noto Sans TC',Arial,sans-serif;"
      >
        分享觀點、紀錄思考
      </p>
    </header>

    <ArticleArchive client:load posts={postsData} allTags={allTags} />
  </main>
</BlogLayout>

<style is:global>
  .card-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }
  .card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 12px;
    border: 1px solid #e8e8e8;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      box-shadow 180ms ease,
      transform 180ms ease;
  }
  .card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.09);
    transform: translateY(-2px);
  }
  .card-cover {
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .card-cover-shape1 {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    opacity: 0.18;
    position: absolute;
    top: 28px;
    left: 28px;
  }
  .card-cover-shape2 {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    opacity: 0.25;
    position: absolute;
    bottom: 20px;
    right: 36px;
  }
  .card-cover-label {
    font-size: 36px;
    font-weight: 700;
    opacity: 0.22;
    user-select: none;
    letter-spacing: -2px;
  }
  .card-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    font-size: 11px;
    font-weight: 500;
    color: #56c7bb;
    background: #eaf8f7;
    border-radius: 999px;
    padding: 2px 8px;
  }
  .card-title {
    font-size: 16px;
    font-weight: 700;
    color: #2e2e2e;
    line-height: 1.4;
  }
  .card-excerpt {
    font-size: 13.5px;
    color: #9a9a9a;
    line-height: 1.65;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    padding-top: 8px;
    border-top: 1px solid #f0f0f0;
  }
  .card-date {
    font-size: 12px;
    color: #c0c0c0;
  }
</style>
